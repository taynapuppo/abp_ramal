@page
@model SistemaRamais.Web.Pages.Graficos.IndexModel
@{
    ViewBag.Title = "Gráficos";
}

<h2>Gráficos</h2>

<canvas id="graficoRamais"></canvas>

@section scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Obtendo os dados passados do controlador
        var dadosGrafico = @Html.Raw(ViewData["DadosGrafico"]);

        var ctx = document.getElementById('graficoRamais').getContext('2d');

        var config = {
            type: 'bar', // Tipo de gráfico: barra
            data: dadosGrafico, // Passando os dados do gráfico
            options: {
                responsive: true, // Tornar o gráfico responsivo
                scales: {
                    y: {
                        beginAtZero: true // Começar o eixo Y no zero
                    }
                }
            }
        };

        var graficoRamais = new Chart(ctx, config);
    </script>
}
